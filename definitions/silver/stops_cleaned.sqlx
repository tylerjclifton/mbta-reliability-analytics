config {
    type: 'incremental',
    schema: 'silver',
    name: 'stops_cleaned',
    tags: ['stops'],
    dependencies: ['stops_raw'],
    protected: true
}

js {
    const {
        delete_statement,
        select_statement
    } = functions_silver.buildDesertSilver('stops');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
