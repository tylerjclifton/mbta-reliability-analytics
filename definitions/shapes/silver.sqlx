config {
    type: 'incremental',
    schema: 'shapes',
    name: 'silver',
    tags: ['shapes'],
    dependencies: [{
        schema: 'shapes',
        name: 'bronze'
    }]
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.buildDesertSilver('shapes');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
