config {
    type: 'incremental',
    dataset: 'mbta',
    name: 'bronze_routes',
    tags: ['routes'],
    protected: true
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.buildDesertBronze('routes');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
