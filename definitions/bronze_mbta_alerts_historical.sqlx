config {
    type: 'incremental',
    schema: 'mbta',
    name: 'bronze_mbta_alerts_historical'
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.BronzeDesert();
}

pre_operations {
  CREATE TEMP TABLE temp AS ${select_statement}
  
  ${when(
    incremental(),
    delete_statement
  )}

}

SELECT * FROM temp