config {
    type: 'incremental',
    schema: 'alerts',
    name: 'alerts_silver',
    tags: ['alerts'],
    dependencies: ['alerts_bronze']
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.buildDesertSilver('alerts');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
