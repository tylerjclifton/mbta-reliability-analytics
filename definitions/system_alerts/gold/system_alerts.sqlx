config {
    type: 'incremental',
    schema: 'gold',
    name: 'system_alerts',
    dependencies: [
        'alerts_enhanced',
        'routes_enhanced'
    ],
    tags: ['mbta']
}

js {
    const {
        deleteStatement,
        selectStatement
    } = functions.desertGold();
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${selectStatement}
    ${
        when(
            incremental(),
            deleteStatement
        )
    }
}
