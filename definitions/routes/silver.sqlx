config {
    type: 'incremental',
    schema: 'routes',
    name: 'routes_cleaned',
    tags: ['routes'],
    dependencies: ['routes_raw']
}

js {
    const {
        delete_statement,
        select_statement
    } = functions_silver.buildDesertSilver('routes');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
