config {
    type: 'incremental',
    schema: 'mbta',
    name: 'bronze_routes'
}

js {
    // import variables
    const schemas = require('/includes/schemas');

    // data set
    const dataSet = schemas.routes.dataSet;

    // tables
    const tableExternal = schemas.routes.tables.external;
    const tableBronze = schemas.routes.tables.bronze;

    // keys
    const key = schemas.routes.fields.key;

    // dimensions
    const dimensions = schemas.routes.fields.dimensions;

    // ingestion info
    const ingestionInfo = schemas.routes.fields.ingestionInfo;

    const {
        deleteStatement,
        selectStatement
    } = functions.desert(
        dataSet,
        tableExternal,
        tableBronze,
        key,
        dimensions,
        ingestionInfo
    );
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${selectStatement}
    ${
        when(
            incremental(),
            deleteStatement
        )
    }
}
