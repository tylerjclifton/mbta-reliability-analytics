config {
    type: 'incremental',
    schema: 'mbta',
    name: 'silver_alerts',
    tags: ['mbta'],
    dependencies: [{
        schema: 'mbta',
        name: 'bronze_alerts'
    }],
    hermetic: true
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.buildDesertSilver('alerts');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
