# Ignore virtual environments
venv/
.venv/
env/

# Ignore dbt artifacts
mbta_analytics_dbt/target/
mbta_analytics_dbt/dbt_packages/
mbta_analytics_dbt/logs/

# Ignore Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Ignore git
.git/
.gitignore

# Ignore IDE
.vscode/
.idea/
*.swp
*.swo

# Ignore macOS
.DS_Store

# Ignore terraform state
terraform/*.tfstate*
terraform/.terraform/

# Ignore logs
logs/
*.log

# Ensure GCP service account key is included
!keys/
!keys/gcp-dbt-sa.json
