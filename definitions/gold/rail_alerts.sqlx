config {
    type: 'incremental',
    schema: 'gold',
    name: 'rail_alerts',
    dependencies: [{
            schema: 'alerts',
            name: 'silver'
        },
        {
            schema: 'routes',
            name: 'silver'
        },,
        {
            schema: 'stops',
            name: 'silver'
        }
    ],
    tags: [
        'alerts',
        'routes',
        'shapes'
    ]
}

js {
    const {
        delete_statement,
        select_statement
    } = functions.buildDesertGold('rail_alerts');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
