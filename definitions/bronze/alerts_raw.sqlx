config {
    type: 'incremental',
    schema: 'bronze',
    name: 'alerts_raw',
    tags: ['alerts'],
    protected: true
}

js {
    const {
        delete_statement,
        select_statement
    } = functions_bronze.buildDesertBronze('alerts');
}

SELECT
  *
FROM
  TEMP

pre_operations {
  CREATE TEMP TABLE TEMP AS ${select_statement}
    ${
        when(
            incremental(),
            delete_statement
        )
    }
}
